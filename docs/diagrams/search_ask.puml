@startuml search_ask
!theme plain
skinparam backgroundColor #FEFEFE

title Search & Ask AI Flow

start

:User enters query;

if (Mode?) then (Search)
  :Send to OpenSearch\n(BM25 multi_match);

  if (OpenSearch available?) then (yes)
    :Return ranked results\nwith highlighted snippets\nand facets;
  else (no)
    :Fallback: scan Postgres\nkeyword scoring;
  endif

  :Display results in UI;
  stop

else (Ask AI)
  :Search OpenSearch\nfor top chunks (top_k * 5);

  :Deduplicate:\n1. Best chunk per document\n2. Fill remaining slots\n   from top-scoring docs;

  :For each chunk, pull\nfull content + neighbors\nfrom Postgres;

  :Build prompt with\nsystem instructions\n+ document excerpts\n+ user question;

  :Send to Bedrock\n(Converse API)\nusing selected Ask AI model;

  :Log token usage\n& estimated cost;

  :Return plain-English\nanswer + citations;

  :Display answer in\ngreen box with\ncitation cards below;
  stop

endif
@enduml
