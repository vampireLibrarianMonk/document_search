APP_ENV=container-local
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=data

# AWS / Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_VISION_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
TRACK_USAGE=true

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Admin_1234!  # pragma: allowlist secret

# Postgres
POSTGRES_USER=docsearch
POSTGRES_PASSWORD=docsearch_local  # pragma: allowlist secret
POSTGRES_DB=docsearch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin  # pragma: allowlist secret
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=documents

# Confluence (cloud, for later)
