n\n\n@app.get(\"/documents/{document_id}/chunks\", response_model=ChunkListResponse)\ndef get_document_chunks(document_id: str) -> ChunkListResponse:\n    document = store.get_document(document_id)\n    if not document:\n        raise HTTPException(status_code=404, detail=\"Document not found\")\n    return ChunkListResponse(document_id=document_id, chunks=store.get_chunks(document_id))\n\n\n@app.post(\"/sources/confluence/sync\", response_model=JobResponse)\ndef confluence_sync(_: ConfluenceSyncRequest) -> JobResponse:\n    # Placeholder for Phase 1: connector comes next.\n    return JobResponse(job_id=store.new_job_id(\"confluence_sync\"), status=\"queued\")\n\n\n@app.get(\"/admin/jobs\", response_model=list[JobResponse])\ndef admin_jobs() -> list[JobResponse]:\n    return store.get_jobs()\n\n\n@app.post(\"/admin/reindex\", response_model=JobResponse)\ndef admin_reindex() -> JobResponse:\n    return JobResponse(job_id=store.new_job_id(\"reindex\"), status=\"queued\")\n\n=== Operation 2 Result (Text) ===\nimport { defineConfig } from \"vite\";\nimport vue from \"@vitejs/plugin-vue\";\n\nexport default defineConfig({\n  plugins: [vue()],\n  server: {\n    host: \"0.0.0.0\",\n    port: 5173,\n  },\n});\n\n=== Operation 3 Result (Text) ===\nimport { createApp, h, reactive } from \"vue\";\n\ntype SearchResult = {\n  document_id: string;\n  chunk_id: string;\n  title: string;\n  snippet: string;\n  score: number;\n  source_type: string;\n  document_type: string;\n};\n\nconst apiBase = \"http://localhost:8000\";\n\nconst state = reactive({\n  uploadFile: null as File | null,\n  query: \"\",\n  question: \"\",\n  results: [] as SearchResult[],\n  answer: \"\",\n  citations: [] as Array<{ document_id: string; chunk_id: string; title: string; snippet: string }>,\n  documents: [] as Array<{ document_id: string; title: string; document_type: string; status: string }>,\n  status: \"Ready\",\n});\n\nasync function loadDocuments() {\n  const res = await fetch(`${apiBase}/documents`);\n  state.documents = await res.json();\n}\n\nasync function upload() {\n  if (!state.uploadFile) {\n    state.status = \"Choose a file first\";\n    return;\n  }\n  const body = new FormData();\n  body.append(\"file\", state.uploadFile);\n\n  const res = await fetch(`${apiBase}/ingest/upload`, { method: \"POST\", body });\n  if (!res.ok) {\n    state.status = `Upload failed: ${await res.text()}`;\n    return;\n  }\n  const data = await res.json();\n  state.status = `Uploaded. document_id=${data.document_id}`;\n  await loadDocuments();\n}\n\nasync function search() {\n  const res = await fetch(`${apiBase}/search`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ query: state.query, mode: \"hybrid\", filters: {}, page: 1, page_size: 10 }),\n  });\n  const data = await res.json();\n  state.results = data.results || [];\n}\n\nasync function ask() {\n  const res = await fetch(`${apiBase}/ask`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ question: state.question, filters: {}, top_k: 5 }),\n  });\n  const data = await res.json();\n  state.answer = data.answer || \"\";\n  state.citations = data.citations || [];\n}\n\ncreateApp({\n  setup() {\n    loadDocuments();\n    return () =>\n      h(\"div\", { style: \"font-family: Arial, sans-serif; max-width: 1000px; margin: 20px auto;\" }, [\n        h(\"h1\", \"House Document Search — Phase 1\"),\n        h(\"p\", { style: \"color:#444\" }, state.status),\n\n        h(\"section\", { style: \"padding:12px; border:1px solid #ddd; margin-bottom:16px;\" }, [\n          h(\"h2\", \"Upload\"),\n          h(\"input\", {\n            type: \"file\",\n            onChange: (e: Event) => {\n              const target = e.target as HTMLInputElement;\n              state.uploadFile = target.files?.[0] || null;\n            },\n          }),\n          h(\"button\", { onClick: upload, style: \"margin-left:8px;\" }, \"Upload\"),\n        ]),\n\n        h(\"section\", { style: \"padding:12px; border:1px solid #ddd; margin-bottom:16px;\" }, [\n          h(\"h2\", \"Search\"),\n          h(\"input\", {\n            value: state.query,\n            placeholder: \"Find HOA rules about sheds\",\n            onInput: (e: Event) => (state.query = (e.target as HTMLInputElement).value),\n            style: \"width:70%; padding:6px;\",\n          }),\n          h(\"button\", { onClick: search, style: \"margin-left:8px;\" }, \"Search\"),\n          h(\n            \"ul\",\n            state.results.map((r) =>\n              h(\"li\", { style: \"margin:8px 0;\" }, `${r.title} [${r.document_type}] score=${r.score} — ${r.snippet}`)\n            )\n          ),\n        ]),\n\n        h(\"section\", { style: \"padding:12px; border:1px solid #ddd; margin-bottom:16px;\" }, [\n          h(\"h2\", \"Ask\"),\n          h(\"input\", {\n            value: state.question,\n            placeholder: \"What does the inspection say about the roof?\",\n            onInput: (e: Event) => (state.question = (e.target as HTMLInputElement).value),\n            style: \"width:70%; padding:6px;\",\n          }),\n          h(\"button\", { onClick: ask, style: \"margin-left:8px;\" }, \"Ask\"),\n          state.answer ? h(\"p\", { style: \"margin-top:10px;\" }, state.answer) : null,\n          h(\n            \"ul\",\n            state.citations.map((c) => h(\"li\", `${c.title} (${c.chunk_id}): ${c.snippet}`))\n          ),\n        ]),\n\n        h(\"section\", { style: \"padding:12px; border:1px solid #ddd;\" }, [\n          h(\"h2\", \"Documents\"),\n          h(\n            \"ul\",\n            state.documents.map((d) => h(\"li\", `${d.title} (${d.document_type}) status=${d.status}`))\n          ),\n        ]),\n      ]);\n  },\n}).mount(\"#app\");"
